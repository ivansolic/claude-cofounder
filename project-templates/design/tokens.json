{
  "$description": "Design tokens (W3C DTCG format). SOURCE OF TRUTH for styling. Edit here (or via /setup-design), then compile to your framework theme. Components reference SEMANTIC tokens only, never primitives, never hardcoded values. Replace the placeholder values with your brand. Figma Tokens Studio can export to this format.",

  "primitive": {
    "color": {
      "$type": "color",
      "brand":   { "500": { "$value": "#3b82f6" }, "600": { "$value": "#2563eb" } },
      "neutral": { "0": { "$value": "#ffffff" }, "50": { "$value": "#f8fafc" }, "200": { "$value": "#e2e8f0" }, "500": { "$value": "#64748b" }, "900": { "$value": "#0f172a" } },
      "red":     { "500": { "$value": "#ef4444" } },
      "green":   { "500": { "$value": "#22c55e" } },
      "amber":   { "500": { "$value": "#f59e0b" } }
    },
    "space": {
      "$type": "dimension",
      "1": { "$value": "4px" }, "2": { "$value": "8px" }, "3": { "$value": "12px" },
      "4": { "$value": "16px" }, "6": { "$value": "24px" }, "8": { "$value": "32px" }, "12": { "$value": "48px" }
    },
    "font": {
      "family": { "$type": "fontFamily", "sans": { "$value": "Inter, system-ui, sans-serif" } },
      "size":   { "$type": "dimension", "sm": { "$value": "14px" }, "md": { "$value": "16px" }, "lg": { "$value": "20px" }, "xl": { "$value": "24px" }, "2xl": { "$value": "32px" } },
      "weight": { "$type": "fontWeight", "regular": { "$value": 400 }, "medium": { "$value": 500 }, "bold": { "$value": 700 } },
      "lineHeight": { "$type": "number", "tight": { "$value": 1.25 }, "body": { "$value": 1.5 } }
    },
    "radius": { "$type": "dimension", "sm": { "$value": "4px" }, "md": { "$value": "8px" }, "full": { "$value": "9999px" } }
  },

  "semantic": {
    "color": {
      "$type": "color",
      "action":     { "primary": { "$value": "{primitive.color.brand.500}" }, "primaryHover": { "$value": "{primitive.color.brand.600}" } },
      "text":       { "default": { "$value": "{primitive.color.neutral.900}" }, "muted": { "$value": "{primitive.color.neutral.500}" }, "onAction": { "$value": "{primitive.color.neutral.0}" } },
      "background": { "default": { "$value": "{primitive.color.neutral.0}" }, "subtle": { "$value": "{primitive.color.neutral.50}" } },
      "border":     { "default": { "$value": "{primitive.color.neutral.200}" } },
      "feedback":   { "danger": { "$value": "{primitive.color.red.500}" }, "success": { "$value": "{primitive.color.green.500}" }, "warning": { "$value": "{primitive.color.amber.500}" } }
    }
  }
}
